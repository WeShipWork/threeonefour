{
    "name": "@weshipwork/pi-herdr",
    "version": "0.1.0",
    "description": "Pi extension for orchestrating herdr workspaces, tabs, and panes from inside herdr.",
    "license": "MIT",
    "type": "module",
    "keywords": [
        "pi-package",
        "pi",
        "pi-coding-agent",
        "herdr",
        "terminal",
        "orchestration"
    ],
    "pi": {
        "extensions": [
            "./extensions/herdr.ts"
        ]
    },
    "scripts": {
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "node --import tsx --test \"tests/**/*.test.ts\"",
        "check": "pnpm run typecheck && pnpm test"
    },
    "peerDependencies": {
        "@earendil-works/pi-ai": "*",
        "@earendil-works/pi-coding-agent": "*",
        "@earendil-works/pi-tui": "*",
        "typebox": "*"
    },
    "peerDependenciesMeta": {
        "@earendil-works/pi-ai": {
            "optional": true
        },
        "@earendil-works/pi-coding-agent": {
            "optional": true
        },
        "@earendil-works/pi-tui": {
            "optional": true
        },
        "typebox": {
            "optional": true
        }
    },
    "devDependencies": {
        "@earendil-works/pi-ai": "^0.80.2",
        "@earendil-works/pi-coding-agent": "^0.80.2",
        "@earendil-works/pi-tui": "^0.80.2",
        "@types/node": "^24.10.1",
        "tsx": "^4.20.6",
        "typebox": "^1.1.24",
        "typescript": "^5.9.3"
    },
    "files": [
        "extensions/",
        "README.md",
        "package.json",
        "tsconfig.json"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/WeShipWork/threeonefour.git",
        "directory": "packages/pi-herdr"
    },
    "homepage": "https://github.com/WeShipWork/threeonefour/tree/main/packages/pi-herdr",
    "bugs": {
        "url": "https://github.com/WeShipWork/threeonefour/issues"
    },
    "author": "brandon@weship.work",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=22.19.0"
    },
    "packageManager": "pnpm@11.6.0"
}
